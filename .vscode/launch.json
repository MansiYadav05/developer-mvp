{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Server",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/server.ts",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Launch Chrome",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Debug Server", "Launch Chrome"]
    }
  ]
}
